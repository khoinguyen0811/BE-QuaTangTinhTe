        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "label_id": { "type": "string", "description": "Mã vận đơn của GHTK", "example": "GHTK.123456.789" },
                  "partner_id": { "type": "string", "description": "Mã đơn hàng tương ứng trên website", "example": "ORD-ABCDE12345" },
                  "status_id": { "type": "integer", "description": "ID trạng thái giao hàng từ GHTK", "example": 5 },
                  "action_time": { "type": "string", "example": "2026-06-25 22:00:00" },
                  "fee": { "type": "number", "description": "Phí ship thực tế GHTK tính", "example": 22000.00 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Đồng bộ trạng thái thành công" },
          "401": { "description": "Token không hợp lệ" },
          "404": { "description": "Đơn hàng đối ứng trên hệ thống không tồn tại" }
        }
      }
    }
